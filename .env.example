# Server port (default: 3000)
PORT=3000

# Data directory for user files (default: project root)
STATERA_DATA_DIR=

# Steam Web API key (for future Steam OAuth)
STEAM_API_KEY=

# Supabase (for future web hosting migration)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Admin password for first-time setup (optional - setup.js will prompt if not set)
STATERA_ADMIN_PASSWORD=
